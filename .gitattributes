# ============================================================
# Git LFS — Content/Game/ 자체 제작 에셋만 추적
# Content/External/ 은 .gitignore로 제외
# ============================================================

# UE5 에셋 바이너리
Content/Game/**/*.uasset filter=lfs diff=lfs merge=lfs -text
Content/Game/**/*.umap filter=lfs diff=lfs merge=lfs -text

# ExternalActors/Objects (OFPA — One File Per Actor, 맵과 연동)
Content/__ExternalActors__/**/* filter=lfs diff=lfs merge=lfs -text
Content/__ExternalObjects__/**/* filter=lfs diff=lfs merge=lfs -text

# 텍스처 / 이미지
Content/Game/**/*.png filter=lfs diff=lfs merge=lfs -text
Content/Game/**/*.tga filter=lfs diff=lfs merge=lfs -text
Content/Game/**/*.jpg filter=lfs diff=lfs merge=lfs -text
Content/Game/**/*.jpeg filter=lfs diff=lfs merge=lfs -text
Content/Game/**/*.exr filter=lfs diff=lfs merge=lfs -text
Content/Game/**/*.hdr filter=lfs diff=lfs merge=lfs -text

# 오디오
Content/Game/**/*.wav filter=lfs diff=lfs merge=lfs -text
Content/Game/**/*.mp3 filter=lfs diff=lfs merge=lfs -text
Content/Game/**/*.ogg filter=lfs diff=lfs merge=lfs -text

# 3D 소스 파일
Content/Game/**/*.fbx filter=lfs diff=lfs merge=lfs -text
Content/Game/**/*.obj filter=lfs diff=lfs merge=lfs -text
